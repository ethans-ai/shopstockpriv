<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>Labels — Dymo 30334</title>
<style>
  @page { size: 2.25in 1.25in; margin: 0; }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: Arial, Helvetica, sans-serif; background: #fff; color: #000; color-scheme: only light; }
  .label {
    width: 2.25in; height: 1.25in;
    padding: 0.08in 0.1in;
    overflow: hidden;
    page-break-after: always;
  }
  .label.qr { display: flex; align-items: center; gap: 0.1in; }
  .label.qr .code-img { width: 1in; height: 1in; flex: 0 0 auto; }
  .label.qr .name {
    font-size: 9pt; font-weight: bold; line-height: 1.15;
    display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
  }
  .label.c128 { display: flex; flex-direction: column; justify-content: space-between; }
  .label.c128 .code-img { width: 100%; height: 0.44in; }
  .label.c128 .name {
    font-size: 9pt; font-weight: bold; line-height: 1.15;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .label.c128 .bottom { display: flex; gap: 0.08in; align-items: baseline; }
  .code-img svg { width: 100%; height: 100%; }
  .txt { min-width: 0; }
  .sub { font-size: 6.5pt; color: #333; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .code { font-size: 8.5pt; font-family: Consolas, monospace; letter-spacing: 0.08em; }
  .print-note { padding: 8px; background: #ffec9e; font-size: 14px; }
  @media print { .print-note { display: none; } }
</style>
</head>
<body>
<div class="print-note">
  Dymo 30334 roll · print at <strong>100% scale, margins: none</strong>.
  <% if (sym === 'qr' && !baseUrlSet) { %><strong style="color:#b00">⚠️ Base URL not set!</strong><% } %>
  <button onclick="print()">Print</button>
</div>
<% for (const l of labels) { %>
  <% if (sym === 'c128') { %>
    <div class="label c128">
      <div class="name"><%= l.name %></div>
      <div class="code-img"><%- l.codeSvg %></div>
      <div class="bottom">
        <span class="code"><%= l.code %></span>
        <% if (l.sub) { %><span class="sub"><%= l.sub %></span><% } %>
      </div>
    </div>
  <% } else { %>
    <div class="label qr">
      <div class="code-img"><%- l.codeSvg %></div>
      <div class="txt">
        <div class="name"><%= l.name %></div>
        <div class="code"><%= l.code %></div>
        <% if (l.sub) { %><div class="sub"><%= l.sub %></div><% } %>
      </div>
    </div>
  <% } %>
<% } %>
</body>
</html>
