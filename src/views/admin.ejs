<%- include('partials/header') %>

<h1>Admin</h1>

<% if (saved) { %><div class="flash flash-ok">Saved.</div><% } %>

<section>
  <h2>Server config</h2>
  <form method="post" action="/admin/config" class="stack-form">
    <label>Site name
      <input type="text" name="siteName" value="<%= config.siteName %>">
    </label>
    <label>Base URL <small>(what QR codes encode — set to this PC's LAN address before printing labels!)</small>
      <input type="url" name="baseUrl" value="<%= config.baseUrl %>"
             placeholder="http://192.168.1.50:8340">
    </label>
    <% if (!config.baseUrl) { %>
      <div class="flash flash-error"><%- include('partials/icon', { name: 'warning' }) %>Base URL is not set. QR labels printed now will not scan to working links.</div>
    <% } %>
    <button type="submit" class="btn btn-primary">Save</button>
  </form>
  <p class="hint">Port (<%= config.port %>) and data directory are set in <code>config.json</code> and need a restart to change.</p>
</section>

<section>
  <h2>Stats</h2>
  <div class="detail-grid">
    <div><span class="label">Items</span> <%= stats.items %></div>
    <div><span class="label">Locations</span> <%= stats.locations %></div>
    <div><span class="label">People</span> <%= stats.people %></div>
    <div><span class="label">Photos</span> <%= stats.photos %> (<%= (photoUsage.bytes / 1048576).toFixed(1) %> MB)</div>
  </div>
</section>

<section>
  <h2>Categories</h2>
  <ul class="plain-list">
    <% for (const c of categories) { %><li><%= c.name %></li><% } %>
  </ul>
  <form method="post" action="/admin/categories" class="inline-form">
    <input type="text" name="name" placeholder="New category" required>
    <button type="submit" class="btn">Add</button>
  </form>
</section>

<section>
  <h2>Backups</h2>

  <% if (backupFlash === 'busy') { %>
    <div class="flash flash-error"><%- include('partials/icon', { name: 'warning' }) %>A backup is already running — give it a moment.</div>
  <% } else if (backupFlash === 'done' && backup.lastRun) { %>
    <% if (backup.lastRun.ok) { %>
      <div class="flash flash-ok"><%- include('partials/icon', { name: 'check' }) %>Backup written to <code><%= backup.lastRun.dest %></code> (<%= backup.lastRun.sizeText %>).</div>
    <% } else { %>
      <div class="flash flash-error"><%- include('partials/icon', { name: 'error' }) %>Backup failed: <%= backup.lastRun.error %></div>
    <% } %>
  <% } %>
  <% if (destProbe === 'ok') { %>
    <div class="flash flash-ok"><%- include('partials/icon', { name: 'check' }) %>Destination is reachable and writable.</div>
  <% } else if (destProbe === 'err') { %>
    <div class="flash flash-error"><%- include('partials/icon', { name: 'warning' }) %>Settings saved, but the destination could not be written right now: <%= destProbeMsg %></div>
  <% } %>

  <% if (backup.lastOk) { %>
    <div class="detail-grid">
      <div><span class="label">Last good backup</span> <%= backup.lastOk.whenText %> (<%= backup.lastOk.agoText %>)</div>
      <div><span class="label">Size</span> <%= backup.lastOk.sizeText %></div>
      <div><span class="label">Written to</span> <code class="backup-path"><%= backup.lastOk.dest %></code></div>
      <% if (backup.nextDueText) { %><div><span class="label">Next automatic</span> <%= backup.nextDueText %></div><% } %>
    </div>
  <% } else { %>
    <p class="hint">No successful backups yet.</p>
  <% } %>
  <% if (backup.lastRun && !backup.lastRun.ok && backupFlash !== 'done') { %>
    <div class="flash flash-error"><%- include('partials/icon', { name: 'error' }) %>Last backup attempt failed <%= backup.lastRun.agoText %>: <%= backup.lastRun.error %></div>
  <% } %>
  <% if (!backup.configured) { %>
    <div class="flash flash-error"><%- include('partials/icon', { name: 'warning' }) %>No off-PC backup destination is set. "Back up now" writes to <code><%= backup.localDir %></code> on <strong>this PC</strong> — that will not survive losing the PC. Automatic backups stay off until a destination is set below.</div>
  <% } %>

  <form method="post" action="/admin/backup-config" class="stack-form">
    <label>Backup destination folder <small>(network share, UNC path, or second drive — whatever IT provides; leave blank until decided)</small>
      <input type="text" name="backupDest" value="<%= config.backupDest %>"
             placeholder="\\fileserver\share\shopstock-backups">
    </label>
    <label>Automatic backup interval, hours <small>(runs while the app is open, once the last backup is older than this; 0 turns automatic backups off)</small>
      <input type="number" name="backupIntervalHours" value="<%= config.backupIntervalHours %>" min="0" step="any">
    </label>
    <label>Keep backups, days <small>(older zips at the destination are deleted after a successful backup; the newest one is always kept; 0 keeps everything)</small>
      <input type="number" name="backupKeepDays" value="<%= config.backupKeepDays %>" min="0" step="any">
    </label>
    <button type="submit" class="btn btn-primary">Save backup settings</button>
  </form>

  <form method="post" action="/admin/backup" class="inline-form">
    <button type="submit" class="btn" <%= backup.running ? 'disabled' : '' %>>Back up now</button>
  </form>
  <p class="hint">Each backup is one zip: a consistent database snapshot (safe while the app is in use), all photos, and a manifest. To restore onto this or a new PC, run <code>scripts\restore.ps1 -Zip &lt;backup zip&gt;</code> — see <code>docs\DEPLOY.md</code>.</p>

  <% if (backup.runs.length) { %>
    <ul class="plain-list backup-runs">
      <% for (const r of backup.runs) { %>
        <li class="<%= r.ok ? 'run-ok' : 'run-fail' %>">
          <%- include('partials/icon', { name: r.ok ? 'check' : 'error' }) %>
          <%= r.whenText %> (<%= r.agoText %>) · <%= r.source %> ·
          <% if (r.ok) { %><%= r.sizeText %><% } else { %><span class="run-error"><%= r.error %></span><% } %>
        </li>
      <% } %>
    </ul>
  <% } %>
</section>

<section>
  <h2>Label calibration</h2>
  <p class="hint">Print this test page at 100% scale and check the ruler against a real one.</p>
  <a class="btn" href="/labels/print-ruler" target="_blank">Open ruler test page</a>
</section>

<%- include('partials/footer') %>
